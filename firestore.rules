rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Specific Validations ---

    function isValidUser(data) {
      return data.userId == request.auth.uid 
        && data.keys().hasAll(['userId'])
        // Optional fields check
        && (!data.keys().contains('categories') || data.categories is list)
        && (!data.keys().contains('onboardingComplete') || data.onboardingComplete is bool);
    }

    function isValidLog(data) {
      return data.userId == request.auth.uid
        && data.date is string && data.date.size() == 10 // YYYY-MM-DD
        && data.hour is int && data.hour >= 0 && data.hour <= 23
        && data.categoryId is string && data.categoryId.size() <= 64
        && data.activity is string && data.activity.size() <= 500
        && (!data.keys().contains('durationMinutes') || (data.durationMinutes is int && data.durationMinutes >= 0 && data.durationMinutes <= 60))
        && data.createdAt == request.time;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid
        && data.categoryId is string && data.categoryId.size() <= 64
        && data.targetHoursPerDay is number && data.targetHoursPerDay >= 0 && data.targetHoursPerDay <= 24
        && (!data.keys().contains('specificObjectives') || (data.specificObjectives is string && data.specificObjectives.size() <= 1000))
        && (!data.keys().contains('isActive') || data.isActive is bool);
    }

    function isValidJournal(data) {
      return data.userId == request.auth.uid
        && data.date is string && data.date.size() == 10
        && data.content is string && data.content.size() <= 5000
        && data.createdAt == request.time;
    }

    function isValidReminder(data) {
      return data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.time is timestamp
        && (!data.keys().contains('isCompleted') || data.isCompleted is bool);
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['categories', 'onboardingComplete']);
    }

    match /activityLogs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(logId) && isValidLog(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidLog(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['activity', 'categoryId', 'durationMinutes']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /goals/{goalId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidGoal(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['targetHoursPerDay', 'specificObjectives', 'isActive']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /journals/{journalId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(journalId) && isValidJournal(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidJournal(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mood']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /reminders/{reminderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(reminderId) && isValidReminder(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidReminder(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'time', 'isCompleted', 'category']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
